# Free webhook for order delivery.
# Recommended: Cloudflare Worker / Google Apps Script / Make webhook with CORS enabled.
# If empty, the site falls back to direct Telegram chat.
NEXT_PUBLIC_ORDER_WEBHOOK_URL=

# Airtable integration (for npm run sync-catalog)
# Personal Access Token: https://airtable.com/create/tokens
AIRTABLE_API_KEY=
# Base ID: найдите в URL вашей базы — https://airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=
# Название таблицы (по умолчанию "Catalog")
AIRTABLE_TABLE_NAME=Catalog
